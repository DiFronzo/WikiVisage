#: app.py:2651 app.py:2778
#, python-format
msgid ""
"Warning: You currently have %(confirmed)d/%(min)d human-confirmed target "
"faces. Autonomous inference will not run until this threshold is met."
msgstr ""
"Attention\\u00a0: Vous avez actuellement %(confirmed)d/%(min)d visages "
"cibles confirmés par un humain. L'inférence autonome ne s'exécutera pas "
"tant que ce seuil ne sera pas atteint."

#: app.py:2661 app.py:2788
#, python-format
msgid ""
"Tip: You have %(count)d bootstrapped matches from existing Commons "
"depicts claims. Approve them in Model Results to count them as human-"
"confirmed."
msgstr ""
"Astuce : Vous avez %(count)d correspondances bootstrap provenant de "
"déclarations depicts existantes sur Commons. Approuvez-les dans les "
"Résultats du Modèle pour les compter comme confirmées par un humain."

