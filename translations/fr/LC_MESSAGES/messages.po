msgid "Failed to update settings."
msgstr "Échec de la mise à jour des paramètres."

#: app.py:2705
msgid "Settings have not changed since the last inference run. No re-run needed."
msgstr ""
"Les paramètres n'ont pas changé depuis la dernière exécution de "
"l'inférence. Aucune ré-exécution nécessaire."

#: app.py:2735
#, python-format
msgid ""
"Reset %(num)d model-classified faces. The worker will re-classify them on"
