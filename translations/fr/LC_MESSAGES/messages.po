msgstr ""
"%(num)d visages classifiés par le modèle ont été réinitialisés. Le worker"
" les reclassifiera au prochain cycle."

#: app.py:2748
msgid "No model-classified faces to reset."
msgstr "Aucun visage classifié par le modèle à réinitialiser."

#: app.py:2768
#, python-format
msgid ""
"You have %(confirmed)d/%(min)d human-confirmed target faces — inference "
"will run on the next worker cycle."
msgstr ""
"Vous avez %(confirmed)d/%(min)d visages cibles confirmés par un humain — "
"l'inférence s'exécutera au prochain cycle du worker."

#: app.py:2799
msgid "Failed to re-run inference."
msgstr "Échec de la relance de l'inférence."

