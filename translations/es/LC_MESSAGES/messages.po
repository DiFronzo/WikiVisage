msgstr "Configuración actualizada."

#: app.py:2651 app.py:2778
#, python-format
msgid ""
"Warning: You currently have %(confirmed)d/%(min)d human-confirmed target "
"faces. Autonomous inference will not run until this threshold is met."
msgstr ""
"Advertencia: Actualmente tienes %(confirmed)d/%(min)d rostros objetivo "
"confirmados por humanos. La inferencia autónoma no se ejecutará hasta que"
" se alcance este umbral."

#: app.py:2661 app.py:2788
#, python-format
msgid ""
"Tip: You have %(count)d bootstrapped matches from existing Commons "
"depicts claims. Approve them in Model Results to count them as human-"
"confirmed."
msgstr ""
"Consejo: Tienes %(count)d coincidencias de bootstrap de declaraciones "
"depicts existentes en Commons. Apruébalas en Resultados del Modelo para "
"contarlas como confirmadas por humanos."

