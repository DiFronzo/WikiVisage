msgid "Wikidata Q-ID must start with 'Q' (e.g., Q42)."
msgstr "El Q-ID de Wikidata debe comenzar con 'Q' (ej. Q42)."

#: app.py:1036
msgid "Commons category is required."
msgstr "Se requiere una categoría de Commons."

#: app.py:1041 app.py:2592
msgid "Distance threshold must be between 0.1 and 1.0."
msgstr "El umbral de distancia debe estar entre 0.1 y 1.0."

#: app.py:1043 app.py:2594
