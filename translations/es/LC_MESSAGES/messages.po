msgstr ""
"Se restablecieron %(num)d rostros clasificados por el modelo. El "
"trabajador los reclasificará en el próximo ciclo."

#: app.py:2748
msgid "No model-classified faces to reset."
msgstr "No hay rostros clasificados por el modelo para restablecer."

#: app.py:2768
#, python-format
msgid ""
"You have %(confirmed)d/%(min)d human-confirmed target faces — inference "
"will run on the next worker cycle."
msgstr ""
"Tienes %(confirmed)d/%(min)d rostros objetivo confirmados por humanos — "
"la inferencia se ejecutará en el próximo ciclo del worker."

#: app.py:2799
msgid "Failed to re-run inference."
msgstr "Error al volver a ejecutar la inferencia."

