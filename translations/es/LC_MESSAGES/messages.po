msgid "Failed to update settings."
msgstr "Error al actualizar la configuración."

#: app.py:2705
msgid "Settings have not changed since the last inference run. No re-run needed."
msgstr ""
"La configuración no ha cambiado desde la última ejecución de inferencia. "
"No es necesario volver a ejecutar."

#: app.py:2735
#, python-format
msgid ""
"Reset %(num)d model-classified faces. The worker will re-classify them on"
