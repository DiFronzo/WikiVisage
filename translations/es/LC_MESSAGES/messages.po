#: templates/project_detail.html:370
#, python-format
msgid ""
"%(count)d unclassified faces remaining. Classify at least %(needed)d more"
" target faces to enable autonomous inference (%(confirmed)d/%(min)d "
"confirmed)."
msgstr ""
"Quedan %(count)d rostros sin clasificar. Clasifica al menos %(needed)d "
