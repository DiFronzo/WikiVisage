msgstr "El mínimo confirmado debe ser al menos 1."

#: app.py:1051 app.py:2602
msgid "Minimum confirmed must be a whole number."
msgstr "El mínimo confirmado debe ser un número entero."

#: app.py:1059
#, python-format
msgid ""
